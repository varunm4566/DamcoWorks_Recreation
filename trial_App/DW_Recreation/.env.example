# Server
PORT=3000
CLIENT_URL=http://localhost:5173

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Database — PostgreSQL (production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=damcoworks
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Database — SQLite (local dev, set USE_SQLITE=true to use)
USE_SQLITE=true
SQLITE_PATH=./damcoworks.db
